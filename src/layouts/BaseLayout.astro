---
import { getLang, getT } from "../i18n/index";

interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
const lang = getLang(Astro.cookies);
const t    = getT(lang);
const defaultDesc = lang === "ru"
  ? "Научно-информационный портал по биомеханике и биохимии"
  : "Scientific information portal on biomechanics and biochemistry";
---

<!doctype html>
<html lang={lang} data-lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description ?? defaultDesc} />
    <title>{title} | {lang === "ru" ? "Биохим" : "Biochem"}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" crossorigin="anonymous" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.css" />
  </head>
  <body class="min-h-screen bg-gray-50 text-gray-900 font-sans flex flex-col">
    <header class="bg-white shadow-sm border-b border-gray-200 sticky top-0 z-50">
      <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center gap-6">

        <!-- Лого -->
        <a href="/" class="flex items-center gap-2.5 group select-none flex-shrink-0">
          <div class="w-8 h-8 rounded-lg bg-brand-500 flex items-center justify-center group-hover:bg-brand-600 transition">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18" class="text-white">
              <path d="M9 3h6M9 3v7l-4.5 9A1 1 0 0 0 5.4 21h13.2a1 1 0 0 0 .9-1.4L15 10V3"/>
              <path d="M7.5 16h9"/>
            </svg>
          </div>
          <span class="text-lg font-bold tracking-tight">
            <span class="text-brand-500">{lang === "ru" ? "Био" : "Bio"}</span><span class="text-gray-900">{lang === "ru" ? "хим" : "chem"}</span>
          </span>
        </a>

        <!-- Поиск по центру -->
        <form action="/search" method="get" class="flex-1 flex items-center gap-1.5 max-w-xl mx-auto" id="header-search-form">
          <div class="relative w-full">
            <svg xmlns="http://www.w3.org/2000/svg" class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400 pointer-events-none" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35M17 11A6 6 0 1 1 5 11a6 6 0 0 1 12 0z"/>
            </svg>
            <input
              type="text"
              name="q"
              id="header-search-input"
              placeholder={t.nav.searchPlaceholder}
              autocomplete="off"
              class="w-full border border-gray-200 rounded-lg pl-9 pr-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent transition-all placeholder:text-gray-400 bg-gray-50 focus:bg-white"
            />
          </div>
          <button
            type="submit"
            id="header-search-btn"
            class="hidden items-center justify-center px-3 py-2 rounded-lg bg-brand-500 text-white text-sm font-medium hover:bg-brand-700 transition flex-shrink-0"
          >
            {t.nav.searchBtn}
          </button>
        </form>

        <!-- Навигация + переключатель языка + Auth -->
        <div class="flex items-center gap-5 text-sm font-medium flex-shrink-0">
          <a href="/sections" class="text-gray-600 hover:text-brand-500 transition">{t.nav.sections}</a>
          <a href="/?sort=views" class="text-gray-600 hover:text-brand-500 transition">{t.nav.popular}</a>

          <div id="auth-area" class="flex items-center gap-3">
            <a href="/login" class="bg-brand-500 text-white px-4 py-1.5 rounded-md hover:bg-brand-700 transition">
              {t.nav.login}
            </a>
          </div>
        </div>

      </nav>
    </header>

    <main class="flex-1 max-w-7xl mx-auto w-full px-4 sm:px-6 lg:px-8 py-8">
      <slot />
    </main>

    <footer class="bg-white border-t border-gray-200 py-6 mt-auto">
      <div class="max-w-7xl mx-auto px-4 flex items-center justify-center gap-4 text-sm text-gray-500">
        <span>© {new Date().getFullYear()} ООО «Биохим» — {t.footer.tagline}</span>
        <button
          id="lang-toggle"
          class="text-xs font-medium text-gray-400 hover:text-brand-500 transition select-none"
        >{lang.toUpperCase()}</button>
      </div>
    </footer>

    <script>
      // Переключатель языка
      document.getElementById("lang-toggle")?.addEventListener("click", () => {
        const current = document.documentElement.dataset.lang ?? "ru";
        const next = current === "ru" ? "en" : "ru";
        document.cookie = `lang=${next}; path=/; max-age=31536000; SameSite=Lax`;
        window.location.reload();
      });
    </script>
    <script>
      // Search button toggle
      (() => {
        const input = document.getElementById("header-search-input") as HTMLInputElement | null;
        const btn   = document.getElementById("header-search-btn");
        if (!input || !btn) return;
        input.addEventListener("input", () => {
          if (input.value.trim()) {
            btn.classList.remove("hidden");
            btn.classList.add("inline-flex");
          } else {
            btn.classList.add("hidden");
            btn.classList.remove("inline-flex");
          }
        });
      })();
    </script>
    <script>
      // Toast
      (() => {
        const msg  = sessionStorage.getItem("toast");
        if (!msg) return;
        sessionStorage.removeItem("toast");
        const lang = document.documentElement.dataset.lang ?? "ru";
        const text = msg === "register"
          ? (lang === "en" ? "Registration successful — welcome!" : "Регистрация прошла успешно — добро пожаловать!")
          : (lang === "en" ? "You have successfully signed in" : "Вы успешно вошли в систему");
        const toast = document.createElement("div");
        toast.className = "fixed top-5 right-5 z-[100] bg-green-600 text-white text-sm font-medium px-5 py-3 rounded-lg shadow-lg transition-opacity duration-500";
        toast.textContent = text;
        document.body.appendChild(toast);
        setTimeout(() => { toast.style.opacity = "0"; setTimeout(() => toast.remove(), 500); }, 3000);
      })();
    </script>
    <script>
      // Auth area
      (async () => {
        const area = document.getElementById("auth-area");
        if (!area) return;
        const lang = document.documentElement.dataset.lang ?? "ru";
        const labels = {
          dashboard: lang === "en" ? "Dashboard" : "Панель",
          logout:    lang === "en" ? "Sign out"  : "Выйти",
        };
        try {
          const res = await fetch("/api/profile", { credentials: "include" });
          if (res.ok) {
            const { data } = await res.json();
            const isEditor = data.role === "editor" || data.role === "admin";
            area.innerHTML = `
              ${isEditor ? `<a href="/admin" class="text-gray-600 hover:text-brand-500 transition text-sm font-medium">${labels.dashboard}</a>` : ""}
              <a href="/profile" id="profile-name-link" class="text-gray-700 font-medium text-sm hover:text-brand-500 transition"></a>
              <button id="logout-btn" class="text-sm text-red-500 hover:text-red-700 transition">${labels.logout}</button>
            `;
            const nameLink = document.getElementById("profile-name-link");
            if (nameLink) nameLink.textContent = data.name;
            document.getElementById("logout-btn")?.addEventListener("click", async () => {
              await fetch("/api/auth/sign_out", { method: "DELETE", credentials: "include" });
              window.location.reload();
            });
          }
        } catch {
          // не авторизован
        }
      })();
    </script>
  </body>
</html>
