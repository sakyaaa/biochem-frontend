---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "Научно-информационный портал по биомеханике и биохимии" } = Astro.props;
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} | Биохим</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link
      rel="preconnect"
      href="https://fonts.googleapis.com"
      crossorigin="anonymous"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.css"
    />
  </head>
  <body class="min-h-screen bg-gray-50 text-gray-900 font-sans flex flex-col">
    <header class="bg-white shadow-sm border-b border-gray-200 sticky top-0 z-50">
      <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
        <a href="/" class="text-xl font-bold text-brand-900 hover:text-brand-700 transition">
          Биохим
        </a>
        <div class="flex items-center gap-6 text-sm font-medium">
          <a href="/sections" class="text-gray-600 hover:text-brand-500 transition">Разделы</a>
          <a href="/section/biomechanics" class="text-gray-600 hover:text-brand-500 transition">Биомеханика</a>
          <a href="/section/biochemistry" class="text-gray-600 hover:text-brand-500 transition">Биохимия</a>
          <form action="/search" method="get" class="flex items-center gap-1">
            <input
              type="text"
              name="q"
              placeholder="Поиск..."
              class="w-28 border border-gray-200 rounded-md px-2 py-1 text-sm focus:outline-none focus:ring-1 focus:ring-brand-500 focus:w-40 transition-all placeholder:text-gray-400"
            />
          </form>
          <div id="auth-area" class="flex items-center gap-3">
            <a href="/login" class="bg-brand-500 text-white px-4 py-1.5 rounded-md hover:bg-brand-700 transition">
              Войти
            </a>
          </div>
        </div>
      </nav>
    </header>

    <main class="flex-1 max-w-7xl mx-auto w-full px-4 sm:px-6 lg:px-8 py-8">
      <slot />
    </main>

    <footer class="bg-white border-t border-gray-200 py-6 mt-auto">
      <div class="max-w-7xl mx-auto px-4 text-center text-sm text-gray-500">
        © {new Date().getFullYear()} ООО «Биохим» — научно-информационный портал
      </div>
    </footer>
    <script>
      // Toast
      (() => {
        const msg = sessionStorage.getItem("toast");
        if (!msg) return;
        sessionStorage.removeItem("toast");
        const text = msg === "register" ? "Регистрация прошла успешно — добро пожаловать!" : "Вы успешно вошли в систему";
        const toast = document.createElement("div");
        toast.className = "fixed top-5 right-5 z-[100] bg-green-600 text-white text-sm font-medium px-5 py-3 rounded-lg shadow-lg transition-opacity duration-500";
        toast.textContent = text;
        document.body.appendChild(toast);
        setTimeout(() => { toast.style.opacity = "0"; setTimeout(() => toast.remove(), 500); }, 3000);
      })();
    </script>
    <script>
      (async () => {
        const area = document.getElementById("auth-area");
        if (!area) return;
        try {
          const res = await fetch("/api/profile", { credentials: "include" });
          if (res.ok) {
            const { data } = await res.json();
            const isEditor = data.role === "editor" || data.role === "admin";
            area.innerHTML = `
              ${isEditor ? '<a href="/admin" class="text-gray-600 hover:text-brand-500 transition text-sm font-medium">Панель</a>' : ""}
              <a href="/profile" id="profile-name-link" class="text-gray-700 font-medium text-sm hover:text-brand-500 transition"></a>
              <button id="logout-btn" class="text-sm text-red-500 hover:text-red-700 transition">Выйти</button>
            `;
            const nameLink = document.getElementById("profile-name-link");
            if (nameLink) nameLink.textContent = data.name;
            document.getElementById("logout-btn")?.addEventListener("click", async () => {
              await fetch("/api/auth/sign_out", { method: "DELETE", credentials: "include" });
              window.location.reload();
            });
          }
        } catch {
          // не авторизован — оставляем кнопку "Войти"
        }
      })();
    </script>
  </body>
</html>
