---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { api } from "../../services/api";
import type { Article, Comment } from "../../services/api";
import { getLang, getT } from "../../i18n/index";

const lang = getLang(Astro.cookies);
const t    = getT(lang);

const { id } = Astro.params;

let article: Article | null = null;
let comments: Comment[] = [];
let error: string | null = null;

try {
  const [articleRes, commentsRes] = await Promise.all([
    api.articles.get(Number(id)),
    api.comments.list(Number(id)),
  ]);
  article = articleRes.data;
  comments = commentsRes.data;
} catch (e) {
  error = t.notFound.title;
}

const locale = lang === "en" ? "en-US" : "ru-RU";
const date = article
  ? new Date(article.created_at).toLocaleDateString(locale, {
      day: "numeric", month: "long", year: "numeric"
    })
  : "";
---

<BaseLayout
  title={article?.title ?? t.notFound.title}
  description={article?.content.substring(0, 160)}
>
  {error || !article ? (
    <div class="text-center py-20">
      <h1 class="text-2xl font-semibold text-gray-700">{t.notFound.title}</h1>
      <a href="/" class="mt-4 inline-block text-brand-500 hover:underline">{t.common.backHome}</a>
    </div>
  ) : (
    <div class="max-w-4xl mx-auto">
      <!-- Хлебные крошки -->
      <nav class="text-sm text-gray-500 mb-6 flex items-center gap-2">
        <a href="/" class="hover:text-brand-500">{t.common.home}</a>
        {article.section && (
          <>
            <span>/</span>
            <a href={`/section/${article.section.slug}`} class="hover:text-brand-500">
              {article.section.name}
            </a>
          </>
        )}
        <span>/</span>
        <span class="text-gray-700 truncate max-w-xs">{article.title}</span>
      </nav>

      <!-- Заголовок статьи -->
      <article class="bg-white rounded-xl border border-gray-200 overflow-hidden">
        <div class="p-8">
          {article.section && (
            <a
              href={`/section/${article.section.slug}`}
              class="text-xs font-semibold text-brand-500 uppercase tracking-wider mb-3 inline-block hover:text-brand-700"
            >
              {article.section.name}
            </a>
          )}

          <h1 class="text-3xl font-bold text-gray-900 leading-tight mb-4">
            {article.title}
          </h1>

          <div class="flex items-center flex-wrap gap-4 text-sm text-gray-500 mb-6 pb-4 border-b border-gray-100">
            <a href={`/author/${article.author.id}`} class="font-medium text-gray-700 hover:text-brand-500 transition">
              {article.author.name}
            </a>
            <span>{date}</span>
            <span>{article.views_count} {t.article.views}</span>
            <div class="ml-auto flex items-center gap-3">
              <button id="share-btn" class="text-sm text-gray-400 hover:text-brand-500 transition flex items-center gap-1.5">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z"/>
                </svg>
                <span id="share-label">{t.article.share}</span>
              </button>
              <div id="bookmark-area"></div>
            </div>
          </div>

          <!-- Теги -->
          {article.tags.length > 0 && (
            <div class="flex gap-2 flex-wrap mb-6">
              {article.tags.map(tag => (
                <a
                  href={`/tag/${tag.id}`}
                  class="px-3 py-1 text-xs bg-blue-50 text-blue-700 rounded-full border border-blue-100 hover:bg-blue-100 transition"
                >
                  {tag.name}
                </a>
              ))}
            </div>
          )}

          <!-- Контент статьи -->
          <div class="prose prose-slate max-w-none" set:html={article.content} />
        </div>
      </article>

      <!-- Комментарии -->
      <section class="mt-8">
        <h2 class="text-xl font-semibold text-gray-800 mb-4">
          {t.article.comments} ({comments.length})
        </h2>

        {comments.length === 0 ? (
          <p class="text-gray-500 text-sm">{t.article.noComments}</p>
        ) : (
          <div class="space-y-4">
            {comments.map(comment => (
              <div class="bg-white rounded-lg border border-gray-200 p-4">
                <div class="flex items-center gap-2 mb-2">
                  <span class="font-medium text-sm text-gray-800">{comment.user.name}</span>
                  <span class="text-xs text-gray-400">
                    {new Date(comment.created_at).toLocaleDateString(locale)}
                  </span>
                </div>
                <p class="text-sm text-gray-700 leading-relaxed">{comment.body}</p>
              </div>
            ))}
          </div>
        )}

        <!-- Форма комментария (требует JS) -->
        <div id="comment-form-area" class="mt-6 bg-white rounded-lg border border-gray-200 p-6">
          <h3 class="font-medium text-gray-800 mb-4">{t.article.leaveComment}</h3>
          <p class="text-sm text-gray-500" id="comment-login-hint">
            {t.article.loginToComment} <a href="/login" class="text-brand-500 hover:underline">{t.article.loginLink}</a>.
          </p>
        </div>
      </section>
    </div>
  )}
</BaseLayout>

<script>
  function showErrors(el: HTMLElement, body: { error?: string; errors?: string[] }, fallback = "Произошла ошибка") {
    const messages = body?.errors?.length ? body.errors : [body?.error ?? fallback];
    el.innerHTML = "";
    const icon = document.createElement("span");
    icon.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 flex-shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>`;
    el.appendChild(icon);
    const text = document.createElement("div");
    if (messages.length === 1) {
      text.textContent = messages[0];
    } else {
      const ul = document.createElement("ul");
      ul.className = "list-disc list-inside space-y-0.5";
      messages.forEach(m => { const li = document.createElement("li"); li.textContent = m; ul.appendChild(li); });
      text.appendChild(ul);
    }
    el.appendChild(text);
    el.classList.remove("hidden");
  }

  const lang = document.documentElement.dataset.lang ?? "ru";
  const locale = lang === "en" ? "en-US" : "ru-RU";

  const labels = {
    share:        lang === "en" ? "Share"          : "Поделиться",
    copied:       lang === "en" ? "Copied!"        : "Скопировано!",
    shareError:   lang === "en" ? "Copy error"     : "Ошибка копирования",
    bookmark:     lang === "en" ? "Bookmark"       : "В закладки",
    bookmarkAdded:lang === "en" ? "Bookmarked ✓"   : "В закладках ✓",
    placeholder:  lang === "en" ? "Your comment...": "Ваш комментарий...",
    submit:       lang === "en" ? "Submit"         : "Отправить",
    commentError: lang === "en" ? "Error submitting comment" : "Ошибка отправки комментария",
    comments:     lang === "en" ? "Comments"       : "Комментарии",
  };

  const articleId = window.location.pathname.split("/").pop();
  const formArea = document.getElementById("comment-form-area");
  const loginHint = document.getElementById("comment-login-hint");

  if (formArea && articleId) {
    fetch("/api/profile", { credentials: "include" }).then((res) => {
      if (!res.ok) return;

      loginHint?.remove();
      const form = document.createElement("form");
      form.id = "new-comment-form";
      form.innerHTML = `
        <div id="comment-error" class="hidden bg-red-50 border border-red-200 text-red-700 rounded-lg px-3 py-2.5 text-sm mb-3 flex gap-2"></div>
        <textarea name="body" rows="4" required placeholder="${labels.placeholder}"
          class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 resize-y mb-3"></textarea>
        <button type="submit"
          class="bg-brand-500 text-white px-5 py-2 rounded-lg text-sm font-medium hover:bg-brand-700 transition">
          ${labels.submit}
        </button>
      `;
      formArea.appendChild(form);

      form.addEventListener("submit", async (e) => {
        e.preventDefault();
        const errEl = document.getElementById("comment-error")!;
        errEl.classList.add("hidden");

        const body = (new FormData(form).get("body") as string).trim();
        const postRes = await fetch(`/api/articles/${articleId}/comments`, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          credentials: "include",
          body: JSON.stringify({ comment: { body } }),
        });

        if (postRes.ok) {
          errEl.classList.add("hidden");
          const { data: comment } = await postRes.json();
          const listEl = document.querySelector(".space-y-4") ?? (() => {
            const list = document.createElement("div");
            list.className = "space-y-4";
            const p = document.querySelector("#comment-form-area")!.previousElementSibling;
            p?.replaceWith(list);
            return list;
          })();

          const div = document.createElement("div");
          div.className = "bg-white rounded-lg border border-gray-200 p-4";

          const header = document.createElement("div");
          header.className = "flex items-center gap-2 mb-2";

          const nameSpan = document.createElement("span");
          nameSpan.className = "font-medium text-sm text-gray-800";
          nameSpan.textContent = comment.user.name;

          const dateSpan = document.createElement("span");
          dateSpan.className = "text-xs text-gray-400";
          dateSpan.textContent = new Date(comment.created_at).toLocaleDateString(locale);

          header.appendChild(nameSpan);
          header.appendChild(dateSpan);

          const bodyP = document.createElement("p");
          bodyP.className = "text-sm text-gray-700 leading-relaxed";
          bodyP.textContent = comment.body;

          div.appendChild(header);
          div.appendChild(bodyP);
          listEl.appendChild(div);

          const countEl = document.querySelector("h2");
          if (countEl) {
            const current = parseInt(countEl.textContent?.match(/\d+/)?.[0] ?? "0");
            countEl.textContent = `${labels.comments} (${current + 1})`;
          }

          (form.querySelector("textarea") as HTMLTextAreaElement).value = "";
        } else {
          const j = await postRes.json();
          showErrors(errEl, j, labels.commentError);
        }
      });
    });
  }

  // Bookmark button
  const articleIdForBookmark = window.location.pathname.split("/").pop();
  const bookmarkArea = document.getElementById("bookmark-area");

  if (bookmarkArea && articleIdForBookmark) {
    fetch("/api/profile", { credentials: "include" }).then(async (profileRes) => {
      if (!profileRes.ok) return;

      const bookmarksRes = await fetch("/api/bookmarks", { credentials: "include" });
      let existingBookmarkId: number | null = null;
      if (bookmarksRes.ok) {
        const { data: bookmarks } = await bookmarksRes.json();
        const found = bookmarks.find((b: { article: { id: number }; id: number }) => String(b.article.id) === articleIdForBookmark);
        if (found) existingBookmarkId = found.id;
      }

      renderBookmarkBtn(existingBookmarkId);
    });
  }

  function renderBookmarkBtn(bookmarkId: number | null) {
    if (!bookmarkArea) return;
    bookmarkArea.innerHTML = bookmarkId
      ? `<button id="bm-btn" class="flex items-center gap-2 text-sm text-brand-500 border border-brand-500 rounded-lg px-4 py-1.5 hover:bg-brand-50 transition">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 fill-brand-500" viewBox="0 0 24 24"><path d="M5 3a2 2 0 00-2 2v16l7-3 7 3V5a2 2 0 00-2-2H5z"/></svg>
          ${labels.bookmarkAdded}
        </button>`
      : `<button id="bm-btn" class="flex items-center gap-2 text-sm text-gray-600 border border-gray-300 rounded-lg px-4 py-1.5 hover:bg-gray-50 transition">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3a2 2 0 00-2 2v16l7-3 7 3V5a2 2 0 00-2-2H5z"/></svg>
          ${labels.bookmark}
        </button>`;

    document.getElementById("bm-btn")?.addEventListener("click", async () => {
      if (bookmarkId) {
        const res = await fetch(`/api/bookmarks/${bookmarkId}`, { method: "DELETE", credentials: "include" });
        if (res.ok) { bookmarkId = null; renderBookmarkBtn(null); }
      } else {
        const res = await fetch("/api/bookmarks", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          credentials: "include",
          body: JSON.stringify({ bookmark: { article_id: Number(articleIdForBookmark) } }),
        });
        if (res.ok) {
          const { data } = await res.json();
          bookmarkId = data.id;
          renderBookmarkBtn(bookmarkId);
        }
      }
    });
  }

  // Share button
  document.getElementById("share-btn")?.addEventListener("click", async () => {
    const label = document.getElementById("share-label")!;
    const url = window.location.href;
    try {
      if (navigator.clipboard && window.isSecureContext) {
        await navigator.clipboard.writeText(url);
      } else {
        const ta = document.createElement("textarea");
        ta.value = url;
        ta.style.cssText = "position:fixed;opacity:0;pointer-events:none";
        document.body.appendChild(ta);
        ta.select();
        document.execCommand("copy");
        ta.remove();
      }
      label.textContent = labels.copied;
      setTimeout(() => { label.textContent = labels.share; }, 2000);
    } catch {
      label.textContent = labels.shareError;
      setTimeout(() => { label.textContent = labels.share; }, 2000);
    }
  });
</script>
