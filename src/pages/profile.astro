---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getLang, getT } from "../i18n/index";

const lang = getLang(Astro.cookies);
const t    = getT(lang);
---

<BaseLayout title={t.profile.title}>
  <div class="max-w-4xl mx-auto" id="profile-root">
    <div class="text-center py-20 text-gray-400">{t.common.loading}</div>
  </div>

  <script>
    const root = document.getElementById("profile-root")!;
    const lang = document.documentElement.dataset.lang ?? "ru";

    const L = lang === "en" ? {
      title:          "My profile",
      accountSection: "Account details",
      name:           "Name",
      email:          "Email",
      newPassword:    "New password",
      passwordHint:   "Leave blank to keep unchanged",
      save:           "Save changes",
      bookmarksSection: "My bookmarks",
      noBookmarks:    "No bookmarks yet.",
      removeBookmark: "Remove",
      saveSuccess:    "Profile saved successfully",
      loadError:      "Failed to load profile",
      saveError:      "Save error",
      roles: { guest: "Guest", member: "Member", editor: "Editor", admin: "Administrator" },
    } : {
      title:          "Мой профиль",
      accountSection: "Данные аккаунта",
      name:           "Имя",
      email:          "Email",
      newPassword:    "Новый пароль",
      passwordHint:   "Оставьте пустым, если не меняете",
      save:           "Сохранить изменения",
      bookmarksSection: "Мои закладки",
      noBookmarks:    "Закладок пока нет.",
      removeBookmark: "Удалить",
      saveSuccess:    "Профиль успешно сохранён",
      loadError:      "Ошибка загрузки профиля",
      saveError:      "Ошибка сохранения",
      roles: { guest: "Гость", member: "Участник", editor: "Редактор", admin: "Администратор" },
    };

    const roleBadge: Record<string, string> = {
      admin:  "bg-purple-100 text-purple-700",
      editor: "bg-brand-100 text-brand-700",
      member: "bg-green-100 text-green-700",
      guest:  "bg-gray-100 text-gray-600",
    };

    async function loadProfile() {
      const res = await fetch("/api/profile", { credentials: "include" });
      if (res.status === 401) { window.location.href = "/login"; return; }
      if (!res.ok) {
        root.innerHTML = `<p class="text-red-500 text-center py-10">${L.loadError}</p>`;
        return;
      }
      const { data: user } = await res.json();
      const isEditor = user.role === "editor" || user.role === "admin";
      const [bookRes, artRes] = await Promise.all([
        fetch("/api/bookmarks", { credentials: "include" }),
        isEditor ? fetch("/api/articles?own=true&per_page=1", { credentials: "include" }) : Promise.resolve(null),
      ]);
      const bookmarks  = bookRes.ok ? (await bookRes.json()).data : [];
      const artCount   = artRes && artRes.ok ? ((await artRes.json()).meta?.total_count ?? 0) : null;
      render(user, bookmarks, artCount);
    }

    function initials(name: string) {
      return name.split(" ").slice(0, 2).map(w => w[0]?.toUpperCase() ?? "").join("");
    }

    function render(
      user: { id: number; name: string; email: string; role: string; created_at?: string },
      bookmarks: Array<{ id: number; article: { id: number; title: string } }>,
      artCount: number | null
    ) {
      const roleLabel = L.roles[user.role as keyof typeof L.roles] ?? escHtml(user.role);
      const badgeCls  = roleBadge[user.role] ?? "bg-gray-100 text-gray-600";
      const ini       = initials(user.name);

      const memberSince = user.created_at
        ? new Date(user.created_at).toLocaleDateString(lang === "en" ? "en-US" : "ru-RU", { month: "long", year: "numeric" })
        : "—";

      const statCards = [
        {
          icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z"/>`,
          label: lang === "en" ? "Bookmarks" : "Закладки",
          value: String(bookmarks.length),
          color: "text-brand-600",
        },
        {
          icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>`,
          label: lang === "en" ? "Member since" : "На портале с",
          value: memberSince,
          color: "text-gray-700",
        },
        ...(artCount !== null ? [{
          icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>`,
          label: lang === "en" ? "My articles" : "Мои статьи",
          value: String(artCount),
          color: "text-green-600",
        }] : []),
      ];

      root.innerHTML = `
        <!-- Шапка профиля -->
        <div class="bg-white rounded-2xl border border-gray-200 p-6 mb-4 flex items-center gap-5">
          <div class="w-16 h-16 rounded-full bg-brand-500 flex items-center justify-center text-white text-xl font-bold flex-shrink-0 select-none">
            ${escHtml(ini)}
          </div>
          <div class="flex-1 min-w-0">
            <h1 class="text-xl font-bold text-gray-900 truncate">${escHtml(user.name)}</h1>
            <p class="text-sm text-gray-400 truncate">${escHtml(user.email)}</p>
          </div>
          <span class="px-3 py-1 rounded-full text-xs font-semibold flex-shrink-0 ${badgeCls}">${roleLabel}</span>
        </div>

        <!-- Карточки статистики -->
        <div class="grid grid-cols-${statCards.length} gap-4 mb-4">
          ${statCards.map(c => `
            <div class="bg-white rounded-xl border border-gray-200 px-5 py-4 flex items-center gap-3">
              <div class="w-9 h-9 rounded-lg bg-gray-50 flex items-center justify-center flex-shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">${c.icon}</svg>
              </div>
              <div class="min-w-0">
                <p class="text-xs text-gray-400 leading-tight">${c.label}</p>
                <p class="text-lg font-bold ${c.color} leading-tight truncate">${c.value}</p>
              </div>
            </div>
          `).join("")}
        </div>

        <!-- Основной контент: форма + закладки -->
        <div class="grid grid-cols-1 md:grid-cols-5 gap-6">

          <!-- Форма (3 колонки) -->
          <div class="md:col-span-3 bg-white rounded-2xl border border-gray-200 p-6">
            <h2 class="text-base font-semibold text-gray-800 mb-5">${L.accountSection}</h2>
            <div id="profile-error" class="hidden bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg mb-4 text-sm flex gap-2.5"></div>
            <form id="profile-form" class="space-y-4">
              <div>
                <label class="block text-xs font-medium text-gray-500 uppercase tracking-wide mb-1.5">${L.name}</label>
                <input type="text" name="name" value="${escHtml(user.name)}" required
                  class="w-full border border-gray-200 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent bg-gray-50 focus:bg-white transition" />
              </div>
              <div>
                <label class="block text-xs font-medium text-gray-500 uppercase tracking-wide mb-1.5">${L.email}</label>
                <input type="email" name="email" value="${escHtml(user.email)}" required
                  class="w-full border border-gray-200 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent bg-gray-50 focus:bg-white transition" />
              </div>
              <div>
                <label class="block text-xs font-medium text-gray-500 uppercase tracking-wide mb-1.5">${L.newPassword}</label>
                <input type="password" name="password" minlength="6" placeholder="${L.passwordHint}"
                  class="w-full border border-gray-200 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent bg-gray-50 focus:bg-white transition placeholder:text-gray-300" />
              </div>
              <div class="pt-1">
                <button type="submit"
                  class="w-full bg-brand-500 text-white px-5 py-2.5 rounded-lg text-sm font-medium hover:bg-brand-700 transition">
                  ${L.save}
                </button>
              </div>
            </form>
          </div>

          <!-- Закладки (2 колонки) -->
          <div class="md:col-span-2 bg-white rounded-2xl border border-gray-200 p-6 flex flex-col">
            <h2 class="text-base font-semibold text-gray-800 mb-5">
              ${L.bookmarksSection}
              <span class="ml-1.5 text-xs font-normal text-gray-400">${bookmarks.length}</span>
            </h2>
            <div id="bookmarks-list" class="flex-1 space-y-0 overflow-y-auto">
              ${bookmarks.length === 0
                ? `<div class="flex flex-col items-center justify-center py-10 text-gray-300">
                     <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10 mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                       <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z"/>
                     </svg>
                     <p class="text-sm">${L.noBookmarks}</p>
                   </div>`
                : bookmarks.map((b: { id: number; article: { id: number; title: string } }) => `
                    <div class="group flex items-start gap-2 py-2.5 border-b border-gray-100 last:border-0" id="bookmark-${b.id}">
                      <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 mt-0.5 text-brand-400 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z"/>
                      </svg>
                      <a href="/article/${b.article.id}" class="flex-1 text-sm text-gray-700 hover:text-brand-500 transition leading-snug line-clamp-2">${escHtml(b.article.title)}</a>
                      <button data-id="${b.id}" class="delete-bookmark flex-shrink-0 opacity-0 group-hover:opacity-100 transition text-gray-300 hover:text-red-500 ml-1" title="${L.removeBookmark}">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
                        </svg>
                      </button>
                    </div>
                  `).join("")}
            </div>
          </div>

        </div>
      `;

      document.getElementById("profile-form")?.addEventListener("submit", async (e) => {
        e.preventDefault();
        const errEl = document.getElementById("profile-error")!;
        errEl.classList.add("hidden");

        const fd = new FormData(e.target as HTMLFormElement);
        const body: Record<string, string> = {
          name:  fd.get("name") as string,
          email: fd.get("email") as string,
        };
        const pw = fd.get("password") as string;
        if (pw) body.password = pw;

        const res = await fetch("/api/profile", {
          method: "PATCH",
          headers: { "Content-Type": "application/json" },
          credentials: "include",
          body: JSON.stringify({ user: body }),
        });

        if (res.ok) {
          const { data: updated } = await res.json();
          (document.querySelector('[name="name"]') as HTMLInputElement).value = updated.name;
          (document.querySelector('[name="email"]') as HTMLInputElement).value = updated.email;
          (document.querySelector('[name="password"]') as HTMLInputElement).value = "";
          errEl.classList.add("hidden");
          showSuccess(errEl.parentElement!, L.saveSuccess);
          // Обновить имя и инициалы в шапке
          const ini = initials(updated.name);
          document.querySelector("#profile-root .bg-brand-500")!.textContent = ini;
          (document.querySelector("#profile-root h1") as HTMLElement).textContent = updated.name;
          (document.querySelector("#profile-root p.text-gray-400") as HTMLElement).textContent = updated.email;
        } else {
          const j = await res.json();
          showErrors(errEl, j, L.saveError);
        }
      });

      document.getElementById("bookmarks-list")?.addEventListener("click", async (e) => {
        const btn = (e.target as HTMLElement).closest(".delete-bookmark") as HTMLButtonElement | null;
        if (!btn) return;
        const id = btn.dataset.id!;
        const res = await fetch(`/api/bookmarks/${id}`, { method: "DELETE", credentials: "include" });
        if (res.ok) {
          document.getElementById(`bookmark-${id}`)?.remove();
          const list = document.getElementById("bookmarks-list");
          if (list && list.querySelectorAll("[id^='bookmark-']").length === 0) {
            list.innerHTML = `<div class="flex flex-col items-center justify-center py-10 text-gray-300">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10 mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z"/>
              </svg>
              <p class="text-sm">${L.noBookmarks}</p>
            </div>`;
          }
        }
      });
    }

    function escHtml(s: string) {
      return s.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;");
    }

    function showSuccess(container: HTMLElement, message: string) {
      const existing = container.querySelector(".success-banner");
      if (existing) existing.remove();
      const div = document.createElement("div");
      div.className = "success-banner bg-green-50 border border-green-200 text-green-700 px-4 py-3 rounded-lg mb-4 text-sm flex gap-2.5";
      div.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 flex-shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M20 6L9 17l-5-5"/></svg>`;
      const text = document.createElement("span");
      text.textContent = message;
      div.appendChild(text);
      container.prepend(div);
      setTimeout(() => div.remove(), 4000);
    }

    function showErrors(el: HTMLElement, body: { error?: string; errors?: string[] }, fallback = "Произошла ошибка") {
      const messages = body?.errors?.length ? body.errors : [body?.error ?? fallback];
      el.innerHTML = "";
      const icon = document.createElement("span");
      icon.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 flex-shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>`;
      el.appendChild(icon);
      const text = document.createElement("div");
      if (messages.length === 1) {
        text.textContent = messages[0];
      } else {
        const ul = document.createElement("ul");
        ul.className = "list-disc list-inside space-y-0.5";
        messages.forEach(m => { const li = document.createElement("li"); li.textContent = m; ul.appendChild(li); });
        text.appendChild(ul);
      }
      el.appendChild(text);
      el.classList.remove("hidden");
    }

    loadProfile();
  </script>
</BaseLayout>
