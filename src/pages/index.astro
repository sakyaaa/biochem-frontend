---
import BaseLayout from "../layouts/BaseLayout.astro";
import ArticleCard from "../components/ArticleCard.astro";
import { api } from "../services/api";
import type { PaginationMeta } from "../services/api";

const page = Number(Astro.url.searchParams.get("page") ?? 1);
const sort = Astro.url.searchParams.get("sort") ?? "";

let articles: Awaited<ReturnType<typeof api.articles.list>>["data"] = [];
let sections: Awaited<ReturnType<typeof api.sections.list>>["data"] = [];
let meta: PaginationMeta | null = null;
let error: string | null = null;

try {
  const [articlesRes, sectionsRes] = await Promise.all([
    api.articles.list({ per_page: 9, page, ...(sort ? { sort } : {}) }),
    api.sections.list(),
  ]);
  articles = articlesRes.data;
  meta = articlesRes.meta;
  sections = sectionsRes.data;
} catch (e) {
  error = "Не удалось загрузить данные. Проверьте соединение.";
}

function sortUrl(s: string) {
  return s ? `?sort=${s}` : "/";
}

function pageUrl(p: number) {
  const params = new URLSearchParams();
  if (sort) params.set("sort", sort);
  params.set("page", String(p));
  return `?${params.toString()}`;
}
---

<BaseLayout title="Главная">
  {error && (
    <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded mb-6">
      {error}
    </div>
  )}

  <div class="grid grid-cols-1 lg:grid-cols-4 gap-8">
    <!-- Боковая панель с разделами -->
    <aside class="lg:col-span-1">
      <div class="bg-white rounded-lg border border-gray-200 p-5">
        <h2 class="font-semibold text-gray-800 mb-4 text-lg">Разделы</h2>
        <ul class="space-y-2">
          {sections.map(s => (
            <li>
              <a
                href={`/section/${s.slug}`}
                class="flex items-center justify-between text-sm text-gray-700 hover:text-brand-500 transition py-1"
              >
                <span>{s.name}</span>
                <span class="text-xs text-gray-400 bg-gray-100 rounded-full px-2">
                  {s.articles_count}
                </span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </aside>

    <!-- Основной контент -->
    <div class="lg:col-span-3">
      <div class="mb-6">
        <h1 class="text-3xl font-bold text-gray-900 mb-2">База научных знаний</h1>
        <p class="text-gray-600">Биомеханика и биохимия человеческого организма</p>
      </div>

      <!-- Строка поиска -->
      <form action="/search" method="get" class="mb-8">
        <div class="flex gap-2">
          <input
            type="text"
            name="q"
            placeholder="Поиск: синтез АТФ, биомеханика колена..."
            class="flex-1 border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500"
          />
          <button
            type="submit"
            class="bg-brand-500 text-white px-5 py-2.5 rounded-lg text-sm font-medium hover:bg-brand-700 transition"
          >
            Найти
          </button>
        </div>
      </form>

      <!-- Сортировка -->
      <div class="flex items-center gap-2 mb-6 flex-wrap">
        <span class="text-sm text-gray-500">Сортировка:</span>
        <a
          href={sortUrl("")}
          class={`px-3 py-1.5 text-sm rounded-lg transition ${!sort ? "bg-brand-500 text-white" : "border border-gray-300 text-gray-600 hover:bg-gray-50"}`}
        >
          Новые
        </a>
        <a
          href={sortUrl("views")}
          class={`px-3 py-1.5 text-sm rounded-lg transition ${sort === "views" ? "bg-brand-500 text-white" : "border border-gray-300 text-gray-600 hover:bg-gray-50"}`}
        >
          По просмотрам
        </a>
        <a
          href={sortUrl("oldest")}
          class={`px-3 py-1.5 text-sm rounded-lg transition ${sort === "oldest" ? "bg-brand-500 text-white" : "border border-gray-300 text-gray-600 hover:bg-gray-50"}`}
        >
          Старые
        </a>
      </div>

      <!-- Список статей -->
      {articles.length === 0 ? (
        <div class="text-center py-12 text-gray-500">
          Статьи не найдены
        </div>
      ) : (
        <div class="space-y-4">
          {articles.map(article => (
            <ArticleCard article={article} />
          ))}
        </div>
      )}

      <!-- Пагинация -->
      {meta && meta.total_pages > 1 && (
        <div class="mt-8 flex justify-center gap-2">
          {page > 1 && (
            <a href={pageUrl(page - 1)} class="px-4 py-2 text-sm border border-gray-300 rounded-lg hover:bg-gray-50">
              ← Назад
            </a>
          )}
          <span class="px-4 py-2 text-sm text-gray-600">
            Страница {page} из {meta.total_pages}
          </span>
          {page < meta.total_pages && (
            <a href={pageUrl(page + 1)} class="px-4 py-2 text-sm border border-gray-300 rounded-lg hover:bg-gray-50">
              Далее →
            </a>
          )}
        </div>
      )}
    </div>
  </div>
</BaseLayout>
