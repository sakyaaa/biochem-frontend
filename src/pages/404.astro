---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getLang, getT } from "../i18n/index";

const lang = getLang(Astro.cookies);
const t    = getT(lang);
---

<BaseLayout title={t.notFound.title}>
  <div class="max-w-lg mx-auto text-center py-24">
    <p class="text-8xl font-bold text-brand-100 select-none mb-2">404</p>
    <h1 class="text-2xl font-bold text-gray-900 mb-3">{t.notFound.title}</h1>
    <p class="text-gray-500 mb-8">{t.notFound.hint}</p>
    <div class="flex justify-center gap-3">
      <a
        href="/"
        class="bg-brand-500 text-white px-5 py-2.5 rounded-lg text-sm font-medium hover:bg-brand-700 transition"
      >
        {t.notFound.home}
      </a>
      <a
        href="/search"
        class="border border-gray-300 text-gray-700 px-5 py-2.5 rounded-lg text-sm font-medium hover:bg-gray-50 transition"
      >
        {t.notFound.search}
      </a>
    </div>
  </div>
</BaseLayout>
