---
import BaseLayout from "../../../../layouts/BaseLayout.astro";
---

<BaseLayout title="Редактировать статью">
  <div class="max-w-3xl mx-auto">
    <div class="flex items-center gap-3 mb-8">
      <a href="/admin" class="text-gray-500 hover:text-brand-500 text-sm">← Панель</a>
      <span class="text-gray-300">/</span>
      <h1 class="text-2xl font-bold text-gray-900">Редактировать статью</h1>
    </div>

    <div id="error-msg" class="hidden bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg mb-4 text-sm flex gap-2.5"></div>
    <div id="page-content" class="text-gray-400 text-center py-10">Загрузка...</div>
  </div>

  <script>
    function showErrors(el: HTMLElement, body: { error?: string; errors?: string[] }, fallback = "Произошла ошибка") {
      const messages = body?.errors?.length ? body.errors : [body?.error ?? fallback];
      el.innerHTML = "";
      const icon = document.createElement("span");
      icon.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 flex-shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>`;
      el.appendChild(icon);
      const text = document.createElement("div");
      if (messages.length === 1) {
        text.textContent = messages[0];
      } else {
        const ul = document.createElement("ul");
        ul.className = "list-disc list-inside space-y-0.5";
        messages.forEach(m => { const li = document.createElement("li"); li.textContent = m; ul.appendChild(li); });
        text.appendChild(ul);
      }
      el.appendChild(text);
      el.classList.remove("hidden");
    }

    const errorMsg = document.getElementById("error-msg")!;
    const pageContent = document.getElementById("page-content")!;
    const articleId = window.location.pathname.split("/")[3];
    let allTags: Array<{ id: number; name: string }> = [];
    let allSections: Array<{ id: number; name: string }> = [];

    async function init() {
      const profileRes = await fetch("/api/profile", { credentials: "include" });
      if (profileRes.status === 401) { window.location.href = "/login"; return; }

      const [articleRes, sectionsRes, tagsRes] = await Promise.all([
        fetch(`/api/articles/${articleId}`, { credentials: "include" }),
        fetch("/api/sections", { credentials: "include" }),
        fetch("/api/tags", { credentials: "include" }),
      ]);

      if (!articleRes.ok) {
        pageContent.innerHTML = `<p class="text-red-500">Статья не найдена</p>`;
        return;
      }

      const { data: article } = await articleRes.json();
      if (sectionsRes.ok) allSections = (await sectionsRes.json()).data;
      if (tagsRes.ok)    allTags    = (await tagsRes.json()).data;

      renderForm(article);
    }

    function escHtml(s: string) {
      return s.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;");
    }

    function renderForm(article: { id: number; title: string; content: string; status: string; section: { id: number } | null; tags: Array<{ id: number; name: string }> }) {
      const sectionsOptions = [
        `<option value="">— без раздела —</option>`,
        ...allSections.map((s) =>
          `<option value="${s.id}" ${article.section?.id === s.id ? "selected" : ""}>${escHtml(s.name)}</option>`
        ),
      ].join("");

      const currentTagNames = article.tags.map((t) => t.name).join(", ");

      pageContent.innerHTML = `
        <div class="bg-white rounded-xl border border-gray-200 p-8">
          <form id="article-form" class="space-y-5">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Заголовок</label>
              <input type="text" name="title" required value="${escHtml(article.title)}"
                class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500" />
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Содержимое</label>
              <textarea name="content" rows="12" required
                class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 resize-y">${escHtml(article.content)}</textarea>
            </div>
            <div class="grid grid-cols-2 gap-4">
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Статус</label>
                <select name="status"
                  class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500">
                  <option value="draft" ${article.status === "draft" ? "selected" : ""}>Черновик</option>
                  <option value="published" ${article.status === "published" ? "selected" : ""}>Опубликовано</option>
                </select>
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Раздел</label>
                <select name="section_id"
                  class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500">
                  ${sectionsOptions}
                </select>
              </div>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Теги <span class="text-gray-400 font-normal">(через запятую)</span></label>
              <input type="text" name="tag_ids_raw" value="${escHtml(currentTagNames)}"
                class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500" />
              <div class="mt-1 text-xs text-gray-400">Доступные: ${allTags.map((t) => t.name).join(", ")}</div>
            </div>
            <div class="flex gap-3 pt-2">
              <button type="submit"
                class="bg-brand-500 text-white px-6 py-2 rounded-lg text-sm font-medium hover:bg-brand-700 transition">
                Сохранить
              </button>
              <a href="/admin" class="px-4 py-2 rounded-lg text-sm text-gray-600 border border-gray-300 hover:bg-gray-50 transition">Отмена</a>
            </div>
          </form>
        </div>
      `;

      document.getElementById("article-form")?.addEventListener("submit", async (e) => {
        e.preventDefault();
        errorMsg.classList.add("hidden");
        const fd = new FormData(e.target as HTMLFormElement);

        const rawTags = (fd.get("tag_ids_raw") as string).split(",").map((s) => s.trim().toLowerCase()).filter(Boolean);
        const tagIds = allTags.filter((t) => rawTags.includes(t.name.toLowerCase())).map((t) => t.id);

        const sectionId = fd.get("section_id") as string;
        const body: Record<string, unknown> = {
          title:   fd.get("title"),
          content: fd.get("content"),
          status:  fd.get("status"),
          tag_ids: tagIds,
        };
        if (sectionId) body.section_id = Number(sectionId);

        const res = await fetch(`/api/articles/${articleId}`, {
          method: "PATCH",
          headers: { "Content-Type": "application/json" },
          credentials: "include",
          body: JSON.stringify({ article: body }),
        });

        if (res.ok) {
          window.location.href = "/admin";
        } else {
          const j = await res.json();
          showErrors(errorMsg, j, "Ошибка сохранения");
        }
      });
    }

    init();
  </script>
</BaseLayout>
