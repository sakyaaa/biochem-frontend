---
import BaseLayout from "../layouts/BaseLayout.astro";
import ArticleCard from "../components/ArticleCard.astro";
import { api } from "../services/api";
import type { Article } from "../services/api";

const q = Astro.url.searchParams.get("q") ?? "";
const page = Number(Astro.url.searchParams.get("page") ?? 1);

let articles: Article[] = [];
let total = 0;
let error: string | null = null;

if (q) {
  try {
    const res = await api.articles.list({ q, page, per_page: 20 });
    articles = res.data;
    total = res.meta.total_count;
  } catch (e) {
    error = "Ошибка при выполнении поиска";
  }
}
---

<BaseLayout title={q ? `Поиск: ${q}` : "Поиск"}>
  <div class="max-w-3xl mx-auto">
    <h1 class="text-2xl font-bold text-gray-900 mb-6">Поиск по базе знаний</h1>

    <form action="/search" method="get" class="mb-8">
      <div class="flex gap-2">
        <input
          type="text"
          name="q"
          value={q}
          placeholder="Введите запрос: синтез АТФ, биомеханика..."
          class="flex-1 border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500"
          autofocus
        />
        <button
          type="submit"
          class="bg-brand-500 text-white px-5 py-2.5 rounded-lg text-sm font-medium hover:bg-brand-700 transition"
        >
          Найти
        </button>
      </div>
    </form>

    {error && (
      <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded mb-4">
        {error}
      </div>
    )}

    {q && !error && (
      <p class="text-sm text-gray-500 mb-4">
        По запросу «{q}» найдено результатов: <strong>{total}</strong>
      </p>
    )}

    {articles.length === 0 && q ? (
      <div class="text-center py-12 bg-white rounded-lg border border-gray-200">
        <p class="text-gray-500">Ничего не найдено по запросу «{q}»</p>
        <p class="text-sm text-gray-400 mt-2">Попробуйте изменить формулировку запроса</p>
      </div>
    ) : (
      <div class="space-y-4">
        {articles.map(article => (
          <ArticleCard article={article} />
        ))}
      </div>
    )}
  </div>
</BaseLayout>
